# 服务运行端口
PORT=4000

# 运行环境：development | production | test
NODE_ENV=development

# 前端地址，用于 CORS 白名单（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173

# JWT 配置
# 生产环境建议改用 RS256 + 公私钥文件，并通过密钥管理服务下发
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt 强度（cost factor，建议 >=12）
BCRYPT_SALT_ROUNDS=12

# 速率限制：普通接口
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# PostgreSQL 数据库连接
DATABASE_URL=postgresql://postgres:123456@localhost:5432/eduflow

# DeepSeek AI 配置
DEEPSEEK_API_KEY=sk-73649e9a847843e28dc45e83db89444f
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Redis 缓存配置
# 可选：也可以直接使用 REDIS_URL，例如 redis://127.0.0.1:6379
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Tavily 搜索 API（用于获取最新官方文档，可选）
TAVILY_API_KEY=your_tavily_api_key_here

# 邮件服务配置（用于密码重置）
# 支持 QQ邮箱、163邮箱、Gmail 等 SMTP 服务
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@qq.com
EMAIL_PASS=your_smtp_authorization_code

# 前端地址（用于生成密码重置链接）
FRONTEND_URL=http://localhost:5173

# 阿里云智能语音交互配置（用于语音转文字）
# 获取方式：https://nls-portal.console.aliyun.com/applist
ALIYUN_AK_ID=your_access_key_id
ALIYUN_AK_SECRET=your_access_key_secret
ALIYUN_NLS_APPKEY=your_nls_appkey
